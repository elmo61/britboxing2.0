<?xml version="1.0" encoding="utf-8"?>
<!--
  Pin package restore to the public gallery for this repo. <clear/> drops any
  inherited machine/enterprise feeds (e.g. private Azure DevOps feeds that need
  work auth and 401 on a personal build) so restore only uses nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
